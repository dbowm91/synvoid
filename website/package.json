{
  "name": "maluwaf-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./src/styles.css --minify",
    "copy:css": "cp src/styles.css dist/",
    "build": "npm run build:css && npm run copy:css",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./src/styles.css --watch"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.19"
  }
}
